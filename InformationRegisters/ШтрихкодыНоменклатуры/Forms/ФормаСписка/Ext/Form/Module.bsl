//// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ЭЛЕМЕНТОВ ФОРМЫ

&НаКлиенте
Процедура СформироватьШтрихкод(Команда)

	ПараметрыФормы = Новый Структура("СформироватьНовый", Истина);
	
	ПараметрыФормы.Вставить("Номенклатура"                 , Номенклатура);
	ПараметрыФормы.Вставить("Характеристика"               , ХарактеристикаНоменклатуры);
	ПараметрыФормы.Вставить("ЕдиницаИзмерения"             , ЕдиницаИзмерения);
	ПараметрыФормы.Вставить("ЗаблокироватьНоменклатуру"    , ЗначениеЗаполнено(Номенклатура));
	ПараметрыФормы.Вставить("ЗаблокироватьХарактеристику"  , ЗначениеЗаполнено(ХарактеристикаНоменклатуры));
	ПараметрыФормы.Вставить("ЗаблокироватьЕдиницуИзмерения", ЗначениеЗаполнено(ЕдиницаИзмерения));
	
	ОткрытьФорму("РегистрСведений.ШтрихкодыНоменклатуры.ФормаЗаписи", ПараметрыФормы, ЭтаФорма);
	
КонецПроцедуры

