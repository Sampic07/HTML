	Элементы.Номенклатура.ТолькоПросмотр               = Истина;
	Элементы.ХарактеристикаНоменклатуры.ТолькоПросмотр = Истина;
	Элементы.ЕдиницаИзмерения.ТолькоПросмотр           = Истина;
	Элементы.Штрихкод.ТолькоПросмотр                   = Истина;
	
	// Форма узгарганини текширтириб юборади
	ОповеститьОбИзменении(Тип("СправочникСсылка.ХарактеристикиНоменклатуры"));
	
КонецПроцедуры


