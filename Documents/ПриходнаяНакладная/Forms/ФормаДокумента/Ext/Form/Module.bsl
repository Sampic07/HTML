	Для каждого ТекСтрока Из Элементы.Товары.ВыделенныеСтроки Цикл
		Если Не ПустаяСтрока(Объект.Товары.НайтиПоИдентификатору(ТекСтрока).ПартияНоменклатура) Тогда
			//НовыйМассив = Новый Массив;
			//НовыйМассив.Добавить(Объект.Товары.НайтиПоИдентификатору(ТекСтрока).ПартияНоменклатура);
			СписокПартии.Добавить(Объект.Товары.НайтиПоИдентификатору(ТекСтрока).ПартияНоменклатура);
			//УдалитьПартииНоменклатура();	
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

